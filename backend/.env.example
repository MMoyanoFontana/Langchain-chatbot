# Core auth and security
API_KEY_ENCRYPTION_KEY=your-fernet-key-here
AUTH_SECRET=your-secret-key-here
BACKEND_CORS_ORIGINS=http://localhost:3000

# Database (optional, defaults to SQLite)
# Leave commented for local dev, use Postgres for production
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Pinecone (required for RAG)
PINECONE_API_KEY=your-api-key
PINECONE_INDEX_NAME=your-index-name
PINECONE_NAMESPACE_PREFIX=rag

# Embeddings (optional, falls back to user's stored key)
OPENAI_API_KEY=your-key

# Rate limiting (optional)
RATE_LIMIT_PER_MINUTE=60

# Catalog sync interval in hours (optional)
CATALOG_SYNC_INTERVAL_HOURS=24

# Observability (optional)
LANGSMITH_API_KEY=your-key
LANGSMITH_PROJECT=your-project

# OAuth providers (optional, repeat keys for GITHUB_* and MICROSOFT_*)
GOOGLE_OAUTH_CLIENT_ID=your-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-secret

# Evaluation (optional, for evals)
EVAL_JUDGE_MODEL=groq/llama-3.3-70b
GROQ_API_KEY=your-groq-key
